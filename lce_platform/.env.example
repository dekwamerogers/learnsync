# ── Required in production ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=

DEBUG=False

# Comma-separated list of domains/IPs the app is served from
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database ───────────────────────────────────────────────────────────────────
# Production (cPanel / MySQL):
DB_ENGINE=django.db.backends.mysql
DB_NAME=cpaneluser_dbname
DB_USER=cpaneluser_dbuser
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Local dev (SQLite — omit DB_ENGINE entirely to use SQLite automatically):
# DB_ENGINE=django.db.backends.sqlite3

# ── Optional ────────────────────────────────────────────────────────────────────
# Required if behind a reverse proxy or served on a custom domain (include scheme):
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Log level for Django internals (DEBUG, INFO, WARNING, ERROR)
# DJANGO_LOG_LEVEL=INFO
